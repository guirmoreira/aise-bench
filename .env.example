# --- CONFIGURAÇÃO DO LITELLM PARA AISE-BENCH ---

# Chave da API OpenAI (pode ser "dummy-key" para APIs locais)
OPENAI_API_KEY=sk-proj-xxxxxx

# Chave da API Anthropic (opcional)
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# --- OBSERVABILIDADE (LANGSMITH) ---
# Essencial para salvar os traces da sua pesquisa
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxx
LANGSMITH_PROJECT=Mestrado

# --- MODELO E API ---
# Configurado em exp_config.py, mas pode sobrescrever aqui:
# MODEL=qwen/qwen3-coder-30b
# OPENAI_API_URL=http://127.0.0.1:1234/v1
