2026-03-04 16:08:22:0958 [GENERATION] {{"run_id": "1772640430298-8f1592b9", "task": "regex_engine", "attempt": 1, "tokens_input": 228, "tokens_output": 293, "tokens_total": 521}} <code>
    def regex_match(pattern, text):
        if not pattern:
            return not text
        
        # Check if first character matches
        first_match = bool(text) and pattern[0] in {text[0], '.'}
        
        # Handle '*' - zero or more of the preceding element
        if len(pattern) >= 2 and pattern[1] == '*':
            # Either skip the pattern (zero occurrences) or match one and continue
            return (regex_match(pattern[2:], text) or 
                    (first_match and regex_match(pattern, text[1:])))
        
        # Handle '+' - one or more of the preceding element
        elif len(pattern) >= 2 and pattern[1] == '+':
            # Must match at least one, then can match more
            return first_match and (regex_match(pattern[2:], text[1:]) or 
                                    regex_match(pattern, text[1:]))
        
        # Handle '?' - zero or one of the preceding element
        elif len(pattern) >= 2 and pattern[1] == '?':
            # Either skip the pattern (zero occurrences) or match one and continue
            return regex_match(pattern[2:], text) or (first_match and regex_match(pattern[2:], text[1:]))
        
        # Regular character or '.' match
        else:
            return first_match and regex_match(pattern[1:], text[1:])
    </code>

