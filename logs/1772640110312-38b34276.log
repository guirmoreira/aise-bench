2026-03-04 16:02:25:0148 [GENERATION] {{"run_id": "1772640110312-38b34276", "task": "caesar_cipher", "attempt": 1, "tokens_input": 184, "tokens_output": 84, "tokens_total": 268}} <code>
    def caesar_cipher(text, shift):
        result = []
        
        for char in text:
            if char.isalpha():
                base = ord('A') if char.isupper() else ord('a')
                shifted = (ord(char) - base + shift) % 26
                result.append(chr(shifted + base))
            else:
                result.append(char)
        
        return ''.join(result)
    </code>

